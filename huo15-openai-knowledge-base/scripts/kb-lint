#!/bin/bash
# kb-lint — 知识库体检（Agent 专属版本）

AGENT_DIR="${AGENT_DIR:-$HOME/.openclaw/agents/main/agent}"
KB_DATA_DIR="${AGENT_DIR}/kb"
WIKI_DIR="${KB_DATA_DIR}/wiki"
CACHE_DIR="${KB_DATA_DIR}/cache"

if [ ! -d "$KB_DATA_DIR" ]; then
  echo "⚠️  知识库未激活，请先入库文档"
  exit 1
fi

AGGRESSIVE=false
if [ "$1" = "--aggressive" ]; then
  AGGRESSIVE=true
fi

echo "🔍 知识库体检中..."

# 收集 wiki 条目
ENTRIES=$(find "$WIKI_DIR" -maxdepth 1 -name "*.md" ! -name "index.md" 2>/dev/null || true)

if [ -z "$ENTRIES" ]; then
  echo "⚠️  没有 wiki 条目，请先编译"
  exit 1
fi

ENTRY_COUNT=$(echo "$ENTRIES" | wc -l | tr -d ' ')
echo "  找到 $ENTRY_COUNT 个条目"

# 构建体检 prompt
cat > "$CACHE_DIR/lint_prompt.md" << 'LINT_EOF'
# 知识库体检

检查以下 wiki 条目的健康状况：

### 检查项
- [ ] 文件格式 valid Markdown
- [ ] 每个条目有 type/title/concepts 元信息
- [ ] 摘要简洁（50字内）
- [ ] [[链接]] 都有对应条目
- [ ] 无 orphaned 条目

LINT_EOF

if [ "$AGGRESSIVE" = true ]; then
  echo "" >> "$CACHE_DIR/lint_prompt.md"
  echo "### 深度检查" >> "$CACHE_DIR/lint_prompt.md"
  echo "- [ ] 标记超过 30 天未更新的条目" >> "$CACHE_DIR/lint_prompt.md"
  echo "- [ ] 识别重复内容" >> "$CACHE_DIR/lint_prompt.md"
  echo "- [ ] 建议可合并的相似条目" >> "$CACHE_DIR/lint_prompt.md"
fi

echo "" >> "$CACHE_DIR/lint_prompt.md"
echo "请扫描以下条目并生成 `wiki/_index/health.md` 体检报告：" >> "$CACHE_DIR/lint_prompt.md"
echo "" >> "$CACHE_DIR/lint_prompt.md"

while IFS= read -r entry; do
  echo "### $entry" >> "$CACHE_DIR/lint_prompt.md"
  echo '```' >> "$CACHE_DIR/lint_prompt.md"
  cat "$entry" >> "$CACHE_DIR/lint_prompt.md"
  echo '```' >> "$CACHE_DIR/lint_prompt.md"
  echo "" >> "$CACHE_DIR/lint_prompt.md"
done <<< "$ENTRIES"

echo "📋 体检任务已生成: $CACHE_DIR/lint_prompt.md"
echo ""
echo "⚠️  下一步需要 LLM 介入：告诉 贾维斯 '帮我体检知识库'"
