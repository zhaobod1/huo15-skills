#!/bin/bash
# kb-ingest — 知识库入库（Agent 专属版本）
# 自动使用当前 Agent 的 KB_DATA_DIR
# 支持自动抓取网页内容、微信公众号文章、GitHub README

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_ROOT="$(dirname "$SCRIPT_DIR")"

# 检测 Agent 上下文
AGENT_DIR="${AGENT_DIR:-$HOME/.openclaw/agents/main/agent}"
KB_DATA_DIR="${AGENT_DIR}/kb"
RAW_DIR="${KB_DATA_DIR}/raw"

# 如果未激活，先激活
if [ ! -d "$KB_DATA_DIR" ]; then
  echo "📦 首次使用，正在激活知识库..."
  "$(dirname "$0")/activate.sh"
fi

# 默认值
TYPE="article"
TITLE=""
SOURCE_URL=""
SOURCE_FILE=""
SOURCE_TYPE=""
CONTENT=""
DATE=$(date +%Y-%m-%d)
AUTO_FETCH=true

# 解析参数
while [[ $# -gt 0 ]]; do
  case $1 in
    --url)
      SOURCE_URL="$2"
      TITLE="$2"
      shift 2
      ;;
    --text)
      CONTENT="$2"
      shift 2
      ;;
    --title)
      TITLE="$2"
      shift 2
      ;;
    --type)
      TYPE="$2"
      shift 2
      ;;
    --file)
      SOURCE_FILE="$2"
      shift 2
      ;;
    --source)
      SOURCE_TYPE="$2"
      shift 2
      ;;
    --no-fetch)
      AUTO_FETCH=false
      shift
      ;;
    --method)
      FETCH_METHOD="$2"
      shift 2
      ;;
    *)
      echo "未知参数: $1"
      exit 1
      ;;
  esac
done

if [ -z "$SOURCE_URL" ] && [ -z "$CONTENT" ] && [ -z "$SOURCE_FILE" ] && [ -z "$SOURCE_TYPE" ]; then
  echo "用法:"
  echo "  kb-ingest --url 'https://...'"
  echo "  kb-ingest --url 'https://...' --title '自定义标题'"
  echo "  kb-ingest --url 'https://...' --type paper"
  echo "  kb-ingest --url 'https://...' --method requests  # 指定抓取方式"
  echo "  kb-ingest --url 'https://...' --no-fetch        # 仅创建条目，不抓取内容"
  echo "  kb-ingest --text '内容' --title '标题'"
  echo "  kb-ingest --file /path/to/file.pdf --type paper"
  echo "  kb-ingest --source wechat --url 'https://mp.weixin.qq.com/s/...'  # 微信公众号"
  echo "  kb-ingest --source github --url 'https://github.com/user/repo'     # GitHub README"
  exit 1
fi

# 创建当日目录
TODAY_DIR="$RAW_DIR/$DATE"
mkdir -p "$TODAY_DIR"

# 生成文件名
SAFE_TITLE=$(echo "${TITLE:-$(date +%s)}" | sed 's/[^\w\-]/_/g' | cut -c1-50)
FILENAME="$(date +%Y-%m-%d_%H%M%S)_${TYPE}_${SAFE_TITLE}.md"
DEST="$TODAY_DIR/$FILENAME"

echo "📥 入库中..."

if [ -n "$SOURCE_URL" ]; then
  echo "  来源: $SOURCE_URL"
  
  if [ "$AUTO_FETCH" = true ]; then
    FETCH_CMD=(python3 "$SCRIPT_DIR/kb-fetch" "$SOURCE_URL" --type "$TYPE")
    [ -n "$TITLE" ] && FETCH_CMD+=(--title "$TITLE")
    [ -n "$FETCH_METHOD" ] && FETCH_CMD+=(--method "$FETCH_METHOD")
    FETCH_CMD+=(--output "$DEST")
    
    echo "  🔄 正在抓取内容..."
    FETCH_OUTPUT=$("${FETCH_CMD[@]}" 2>&1) || true
    FETCH_SUCCEEDED=false
    if echo "$FETCH_OUTPUT" | grep -q "已保存\|saved\|✅"; then
      echo "  ✅ 自动抓取成功"
      FETCH_SUCCEEDED=true
    elif echo "$FETCH_OUTPUT" | grep -qi "error\|失败\|failed"; then
      echo "  ⚠️ 自动抓取失败: $(echo "$FETCH_OUTPUT" | grep -im1 "error\|failed\|失败" | head -c 80)"
    else
      FILE_SIZE=$(stat -c%s "$DEST" 2>/dev/null || stat -f%z "$DEST" 2>/dev/null || echo 0)
      if [ -s "$DEST" ] && [ "$FILE_SIZE" -gt 100 ]; then
        echo "  ✅ 自动抓取成功"
        FETCH_SUCCEEDED=true
      else
        echo "  ⚠️ 自动抓取失败（未知原因），创建 pending 条目..."
      fi
    fi
    if [ "$FETCH_SUCCEEDED" != true ]; then
      cat > "$DEST" << EOF
---
type: $TYPE
source: url
url: $SOURCE_URL
date: $DATE
title: "$TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: pending
---

# $TITLE

> 原始内容待抓取

## 摘要


## 关键概念

EOF
    fi
  else
    cat > "$DEST" << EOF
---
type: $TYPE
source: url
url: $SOURCE_URL
date: $DATE
title: "$TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: pending
---

# $TITLE

> 原始内容待抓取

## 摘要


## 关键概念

EOF
  fi

# 新增：微信公众号和 GitHub 仓库支持
elif [ -n "$SOURCE_TYPE" ]; then
  case "$SOURCE_TYPE" in
    wechat)
      echo "  📱 来源类型: 微信公众号文章"
      if [ -z "$SOURCE_URL" ]; then
        echo "错误: --source wechat 需要配合 --url"
        exit 1
      fi
      echo "  🔄 正在抓取微信公众号内容..."
      WEIXIN_CONTENT=$(python3 -c "
import urllib.request, ssl, re
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE
req = urllib.request.Request('$SOURCE_URL', headers={'User-Agent': 'Mozilla/5.0'})
try:
    with urllib.request.urlopen(req, context=ctx, timeout=15) as r:
        html = r.read().decode('utf-8', errors='ignore')
    title_m = re.search(r\"og:title.*?content=\\\"([^\\\"]+)\\\"\", html)
    title = title_m.group(1) if title_m else '$TITLE'
    html_clean = re.sub(r'<script[^>]*>.*?</script>', '', html, flags=re.DOTALL)
    html_clean = re.sub(r'<style[^>]*>.*?</style>', '', html_clean, flags=re.DOTALL)
    text = re.sub(r'<[^>]+>', '', html_clean)
    text = re.sub(r'\s+', ' ', text).strip()
    print(title + '|||' + text[:8000])
except Exception as e:
    print('ERROR:' + str(e))
" 2>&1) || true

      if echo "$WEIXIN_CONTENT" | grep -q "^ERROR:"; then
        echo "  ⚠️ 抓取失败，改为 pending 条目"
        cat > "$DEST" << EOF
---
type: $TYPE
source: wechat
url: $SOURCE_URL
date: $DATE
title: "$TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: pending
---

# $TITLE

> 微信公众号内容抓取失败，请手动复制内容后使用 kb-ingest --text

## 摘要


## 关键概念

EOF
      else
        WEIXIN_TITLE=$(echo "$WEIXIN_CONTENT" | cut -d'|' -f1)
        WEIXIN_BODY=$(echo "$WEIXIN_CONTENT" | cut -d'|' -f2-)
        [ -n "$TITLE" ] && WEIXIN_TITLE="$TITLE"
        echo "  ✅ 抓取成功"
        cat > "$DEST" << EOF
---
type: $TYPE
source: wechat
url: $SOURCE_URL
date: $DATE
title: "$WEIXIN_TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: ready
---

# $WEIXIN_TITLE

## 原文

$WEIXIN_BODY

## 摘要


## 关键概念

EOF
      fi
      ;;

    github)
      echo "  🐙 来源类型: GitHub 仓库 README"
      if [ -z "$SOURCE_URL" ]; then
        echo "错误: --source github 需要配合 --url"
        exit 1
      fi
      echo "  🔄 正在抓取 GitHub README..."

      GITHUB_PATH=$(echo "$SOURCE_URL" | sed -E 's|https?://github\.com/||' | sed 's|/$||')
      GITHUB_API_URL="https://api.github.com/repos/${GITHUB_PATH}/readme"

      README_CONTENT=$(python3 -c "
import urllib.request, ssl
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE
req = urllib.request.Request(
    '$GITHUB_API_URL',
    headers={
        'Accept': 'application/vnd.github.v3.raw',
        'User-Agent': 'huo15-kb-agent'
    }
)
try:
    with urllib.request.urlopen(req, context=ctx, timeout=15) as r:
        content = r.read().decode('utf-8', errors='ignore')
        print(content[:10000])
except urllib.error.HTTPError as e:
    print('ERROR:HTTP:' + str(e.code))
except Exception as e:
    print('ERROR:' + str(e))
" 2>&1) || true

      if echo "$README_CONTENT" | grep -q "^ERROR:"; then
        HTTP_CODE=$(echo "$README_CONTENT" | grep -oP 'ERROR:HTTP:\K\d+' || echo "unknown")
        echo "  ⚠️ GitHub API 请求失败 (HTTP $HTTP_CODE)"
        cat > "$DEST" << EOF
---
type: repo
source: github
url: $SOURCE_URL
date: $DATE
title: "$TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: pending
---

# $TITLE

> GitHub README 抓取失败（HTTP $HTTP_CODE），请手动复制内容后使用 kb-ingest --text

## 摘要


## 关键概念

EOF
      else
        REPO_NAME=$(echo "$GITHUB_PATH" | cut -d'/' -f2)
        [ -n "$TITLE" ] && REPO_NAME="$TITLE"
        echo "  ✅ README 抓取成功"
        cat > "$DEST" << EOF
---
type: repo
source: github
url: $SOURCE_URL
date: $DATE
title: "$REPO_NAME"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: ready
---

# $REPO_NAME

## GitHub
$SOURCE_URL

## README

$README_CONTENT

## 摘要


## 关键概念

EOF
      fi
      ;;

    *)
      echo "错误: 未知的来源类型 '$SOURCE_TYPE'"
      echo "支持的类型: wechat, github"
      exit 1
      ;;
  esac

elif [ -n "$SOURCE_FILE" ]; then
  echo "  来源文件: $SOURCE_FILE"
  if [ ! -f "$SOURCE_FILE" ]; then
    echo "错误: 文件不存在"
    exit 1
  fi
  cp "$SOURCE_FILE" "$DEST"
  
elif [ -n "$CONTENT" ]; then
  echo "  来源: 文本输入"
  cat > "$DEST" << EOF
---
type: $TYPE
source: text
date: $DATE
title: "$TITLE"
ingested: $(date -u +%Y-%m-%dT%H:%M:%SZ)
status: ready
---

$CONTENT
EOF
fi

echo ""
echo "✅ 已入库: $DEST"
echo ""

# 显示状态
if grep -q "status: ready" "$DEST" 2>/dev/null; then
  echo "📄 状态: ready（可直接编译）"
  echo "下一步: kb-compile  # 编译到 wiki"
else
  echo "⏳ 状态: pending（内容待抓取）"
  echo "可用选项:"
  echo "  kb-compile       # 编译（会自动处理 pending 条目）"
  echo "  kb-fetch \"$SOURCE_URL\" --output \"$DEST\"  # 手动抓取"
fi
