#!/bin/bash
# kb-search — 搜索知识库（wiki/ + Obsidian vault）
# 支持 obsidian-cli 深度搜索

set -e

AGENT_DIR="${AGENT_DIR:-$HOME/.openclaw/agents/main/agent}"
KB_DATA_DIR="${AGENT_DIR}/kb"
WIKI_DIR="${KB_DATA_DIR}/wiki"
SKILL_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG_FILE="$SKILL_ROOT/config.json"

# 解析参数
FORMAT="markdown"
QUERY=""
SEARCH_WIKI=true
SEARCH_OBSIDIAN=true

while [[ $# -gt 0 ]]; do
  case $1 in
    -q)
      QUERY="$2"
      shift 2
      ;;
    --format)
      FORMAT="$2"
      shift 2
      ;;
    --wiki-only)
      SEARCH_OBSIDIAN=false
      shift
      ;;
    --obsidian-only)
      SEARCH_WIKI=false
      shift
      ;;
    --help)
      echo "用法: kb-search '关键词' [--format json|markdown] [--wiki-only|--obsidian-only]"
      echo "  --wiki-only      仅搜索本地 wiki/"
      echo "  --obsidian-only  仅搜索 Obsidian vault"
      exit 0
      ;;
    *)
      if [ -z "$QUERY" ]; then
        QUERY="$1"
      fi
      shift
      ;;
  esac
done

if [ -z "$QUERY" ]; then
  echo "用法: kb-search '搜索关键词'"
  exit 1
fi

echo "🔍 搜索: $QUERY"
echo ""

if [ ! -d "$KB_DATA_DIR" ]; then
  echo "⚠️  知识库未激活，请先运行 kb-ingest"
  exit 1
fi

# 读取 Obsidian 配置
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT=""
if [ -f "$CONFIG_FILE" ]; then
  OBSIDIAN_ENABLED=$(python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
print(cfg.get('obsidian', {}).get('enabled', False))
" 2>/dev/null || echo "false")
  OBSIDIAN_VAULT=$(python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
v = cfg.get('obsidian', {}).get('vault_path', '')
print(v if v else '')
" 2>/dev/null || echo "")
fi

# 如果配置文件没有 vault，用 obsidian-cli 发现（来自 obsidian 技能）
if [ -z "$OBSIDIAN_VAULT" ] && command -v obsidian-cli &>/dev/null; then
  OBSIDIAN_VAULT=$(obsidian-cli print-default --path-only 2>/dev/null || echo "")
fi

# 检测 obsidian-cli（来自 obsidian 技能）
OBSIDIAN_CLI=""
if command -v obsidian-cli &>/dev/null; then
  OBSIDIAN_CLI="obsidian-cli"
fi

WIKI_COUNT=0
OBSIDIAN_COUNT=0

search_wiki() {
  local q="$1"
  WIKI_COUNT=0

  if [ ! -d "$WIKI_DIR" ]; then
    return
  fi

  echo "📂 wiki/ ($(ls "$WIKI_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ') 个条目)"
  echo "---"

  RESULTS=$(grep -l -i "$q" "$WIKI_DIR"/*.md "$WIKI_DIR"/**/*.md 2>/dev/null || true)

  if [ -z "$RESULTS" ]; then
    echo "  （无匹配）"
    return
  fi

  while IFS= read -r file; do
    WIKI_COUNT=$((WIKI_COUNT + 1))
    title=$(grep -m1 "^# " "$file" | sed 's/^# //' || basename "$file")
    snippet=$(grep -i -m1 "$q" "$file" | head -c 150 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
    printf "📄 %s\\n   %s\\n   → %s...\\n\\n" "$title" "$file" "$snippet"
  done <<< "$RESULTS"

  echo "   ($WIKI_COUNT 条)"
  echo ""
}

search_obsidian() {
  local q="$1"
  OBSIDIAN_COUNT=0
  local vault_kb_dir="${OBSIDIAN_VAULT}/知识库"

  if [ "$OBSIDIAN_ENABLED" != "True" ] && [ "$OBSIDIAN_ENABLED" != "true" ]; then
    return
  fi

  if [ -z "$OBSIDIAN_VAULT" ] || [ ! -d "$OBSIDIAN_VAULT" ]; then
    return
  fi

  if [ ! -d "$vault_kb_dir" ]; then
    echo "📂 Obsidian vault（知识库/ 目录不存在，跳过）"
    return
  fi

  echo "📂 Obsidian vault（知识库/ $(ls "$vault_kb_dir"/*.md 2>/dev/null | wc -l | tr -d ' ') 个条目）"
  echo "---"

  # 优先用 obsidian-cli search-content（来自 obsidian 技能，搜索 vault 内内容）
  local CLI_RESULTS=""
  if [ -n "$OBSIDIAN_CLI" ]; then
    # 切换到 vault 目录再搜索，确保搜到正确的 vault
    local vault_dir="$OBSIDIAN_VAULT"
    CLI_RESULTS=$(cd "$vault_dir" && obsidian-cli search-content "$q" 2>/dev/null || true)
    if [ -n "$CLI_RESULTS" ]; then
      echo "$CLI_RESULTS" | head -20
      OBSIDIAN_COUNT=$(echo "$CLI_RESULTS" | grep -c "📄\|note" || echo 0)
    fi
  fi

  # 降级：grep 搜索
  if [ -z "$CLI_RESULTS" ] || [ "$CLI_RESULTS" = "$q" ]; then
    OBSIDIAN_RESULTS=$(grep -l -i "$q" "$vault_kb_dir"/*.md "$vault_kb_dir"/**/*.md 2>/dev/null || true)
    if [ -z "$OBSIDIAN_RESULTS" ]; then
      echo "  （无匹配）"
      return
    fi
    while IFS= read -r file; do
      OBSIDIAN_COUNT=$((OBSIDIAN_COUNT + 1))
      title=$(grep -m1 "^# " "$file" | sed 's/^# //' || basename "$file")
      snippet=$(grep -i -m1 "$q" "$file" | head -c 150 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
      printf "📄 %s\\n   %s\\n   → %s...\\n\\n" "$title" "$file" "$snippet"
    done <<< "$OBSIDIAN_RESULTS"
  fi

  echo "   ($OBSIDIAN_COUNT 条)"
  echo ""
}

# 执行搜索
if [ "$SEARCH_WIKI" = true ]; then
  search_wiki "$QUERY"
fi

if [ "$SEARCH_OBSIDIAN" = true ]; then
  search_obsidian "$QUERY"
fi

total=$((WIKI_COUNT + OBSIDIAN_COUNT))
echo "---"
echo "共找到 $total 条结果"
