#!/bin/bash
# kb-search — 搜索知识库（agent + shared + Obsidian vault）
# 默认聚合搜索 agent/shared wiki；可用 --scope 限定单一作用域

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG_FILE="$SKILL_ROOT/config.json"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/kb-scope.sh"

# 解析参数（先走 scope 解析，再解析 kb-search 专属的 --wiki-only / --obsidian-only 等）
kb_parse_scope "$@"
set -- "${KB_ARGS[@]}"

FORMAT="markdown"
QUERY=""
SEARCH_WIKI=true
SEARCH_OBSIDIAN=true
# SCOPE_FILTER: all（默认）/ agent / shared
if [ "${KB_SCOPE_EXPLICIT:-0}" = "1" ]; then
  SCOPE_FILTER="$KB_SCOPE"
else
  SCOPE_FILTER="all"
fi

while [[ $# -gt 0 ]]; do
  case $1 in
    -q)
      QUERY="$2"
      shift 2
      ;;
    --format)
      FORMAT="$2"
      shift 2
      ;;
    --wiki-only)
      SEARCH_OBSIDIAN=false
      shift
      ;;
    --obsidian-only)
      SEARCH_WIKI=false
      shift
      ;;
    --agent-only)
      SCOPE_FILTER="agent"
      shift
      ;;
    --shared-only)
      SCOPE_FILTER="shared"
      shift
      ;;
    --all-scopes)
      SCOPE_FILTER="all"
      shift
      ;;
    --help)
      cat <<HELP
用法: kb-search '关键词' [选项]
  --format json|markdown   输出格式（默认 markdown）
  --wiki-only              仅搜本地 wiki（agent + shared）
  --obsidian-only          仅搜 Obsidian vault
  --agent-only             仅搜当前 Agent 的 kb
  --shared-only            仅搜共享 kb
  --scope agent|shared     同 --agent-only / --shared-only

默认行为：同时搜 agent kb + shared kb + Obsidian（若启用）。
HELP
      exit 0
      ;;
    *)
      if [ -z "$QUERY" ]; then
        QUERY="$1"
      fi
      shift
      ;;
  esac
done

if [ -z "$QUERY" ]; then
  echo "用法: kb-search '搜索关键词'（加 --help 看选项）"
  exit 1
fi

echo "🔍 搜索: $QUERY  (scope: $SCOPE_FILTER)"
echo ""

# 读 Obsidian 配置
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT=""
if [ -f "$CONFIG_FILE" ]; then
  OBSIDIAN_ENABLED=$(python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
print(cfg.get('obsidian', {}).get('enabled', False))
" 2>/dev/null || echo "false")
  OBSIDIAN_VAULT=$(python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
v = cfg.get('obsidian', {}).get('vault_path', '')
print(v if v else '')
" 2>/dev/null || echo "")
fi
if [ -z "$OBSIDIAN_VAULT" ] && command -v obsidian-cli &>/dev/null; then
  OBSIDIAN_VAULT=$(obsidian-cli print-default --path-only 2>/dev/null || echo "")
fi

OBSIDIAN_CLI=""
command -v obsidian-cli &>/dev/null && OBSIDIAN_CLI="obsidian-cli"

TOTAL_COUNT=0

search_wiki_dir() {
  local label="$1"
  local wiki_dir="$2"
  local q="$3"
  local count=0

  if [ ! -d "$wiki_dir" ]; then
    return
  fi

  local entry_count
  entry_count=$(ls "$wiki_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo "📂 $label  ($entry_count 个条目, $wiki_dir)"
  echo "---"

  local results
  results=$(grep -l -i "$q" "$wiki_dir"/*.md "$wiki_dir"/**/*.md 2>/dev/null || true)

  if [ -z "$results" ]; then
    echo "  （无匹配）"
    echo ""
    return
  fi

  while IFS= read -r file; do
    count=$((count + 1))
    local title
    title=$(grep -m1 "^# " "$file" | sed 's/^# //' || basename "$file")
    local snippet
    snippet=$(grep -i -m1 "$q" "$file" | head -c 150 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
    printf "📄 %s\n   %s\n   → %s...\n\n" "$title" "$file" "$snippet"
  done <<< "$results"

  echo "   ($count 条)"
  echo ""
  TOTAL_COUNT=$((TOTAL_COUNT + count))
}

search_obsidian() {
  local q="$1"
  local count=0
  local vault_kb_dir="${OBSIDIAN_VAULT}/知识库"

  if [ "$OBSIDIAN_ENABLED" != "True" ] && [ "$OBSIDIAN_ENABLED" != "true" ]; then
    return
  fi

  if [ -z "$OBSIDIAN_VAULT" ] || [ ! -d "$OBSIDIAN_VAULT" ]; then
    return
  fi

  if [ ! -d "$vault_kb_dir" ]; then
    echo "📂 Obsidian vault（知识库/ 目录不存在，跳过）"
    return
  fi

  local entry_count
  entry_count=$(ls "$vault_kb_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo "📂 Obsidian vault  ($entry_count 个条目, $vault_kb_dir)"
  echo "---"

  local cli_results=""
  if [ -n "$OBSIDIAN_CLI" ]; then
    cli_results=$(cd "$OBSIDIAN_VAULT" && obsidian-cli search-content "$q" 2>/dev/null || true)
    if [ -n "$cli_results" ]; then
      echo "$cli_results" | head -20
      count=$(echo "$cli_results" | grep -c "📄\|note" || echo 0)
    fi
  fi

  if [ -z "$cli_results" ] || [ "$cli_results" = "$q" ]; then
    local obsidian_results
    obsidian_results=$(grep -l -i "$q" "$vault_kb_dir"/*.md "$vault_kb_dir"/**/*.md 2>/dev/null || true)
    if [ -z "$obsidian_results" ]; then
      echo "  （无匹配）"
      echo ""
      return
    fi
    while IFS= read -r file; do
      count=$((count + 1))
      local title
      title=$(grep -m1 "^# " "$file" | sed 's/^# //' || basename "$file")
      local snippet
      snippet=$(grep -i -m1 "$q" "$file" | head -c 150 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
      printf "📄 %s\n   %s\n   → %s...\n\n" "$title" "$file" "$snippet"
    done <<< "$obsidian_results"
  fi

  echo "   ($count 条)"
  echo ""
  TOTAL_COUNT=$((TOTAL_COUNT + count))
}

if [ "$SEARCH_WIKI" = true ]; then
  kb_resolve_agent_dir
  AGENT_WIKI="$AGENT_DIR/kb/wiki"
  SHARED_WIKI="$HOME/.openclaw/kb/shared/wiki"

  case "$SCOPE_FILTER" in
    agent)
      search_wiki_dir "agent wiki" "$AGENT_WIKI" "$QUERY"
      ;;
    shared)
      search_wiki_dir "shared wiki" "$SHARED_WIKI" "$QUERY"
      ;;
    all|*)
      search_wiki_dir "agent wiki" "$AGENT_WIKI" "$QUERY"
      search_wiki_dir "shared wiki" "$SHARED_WIKI" "$QUERY"
      ;;
  esac
fi

if [ "$SEARCH_OBSIDIAN" = true ]; then
  search_obsidian "$QUERY"
fi

echo "---"
echo "共找到 $TOTAL_COUNT 条结果"
