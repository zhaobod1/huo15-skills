#!/bin/bash
# kb-lint — 知识库体检（支持 --scope agent|shared）
# 自动检查 + 可选 LLM 深度分析

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/kb-scope.sh"
kb_parse_scope "$@"
set -- "${KB_ARGS[@]}"

WIKI_DIR="${KB_DATA_DIR}/wiki"
CACHE_DIR="${KB_DATA_DIR}/cache"

if [ ! -d "$KB_DATA_DIR" ]; then
  echo "⚠️  知识库未激活，请先入库文档"
  exit 1
fi

DEEP=false
AGGRESSIVE=false
STALE_DAYS=90

while [[ $# -gt 0 ]]; do
  case $1 in
    --deep)
      DEEP=true
      shift
      ;;
    --aggressive)
      AGGRESSIVE=true
      DEEP=true
      shift
      ;;
    --stale-days)
      STALE_DAYS="$2"
      shift 2
      ;;
    --help)
      echo "用法: kb-lint [--deep] [--aggressive] [--stale-days N]"
      echo "  （默认）        自动检查：frontmatter、断链、stub、orphan、stale、缺出处"
      echo "  --deep          额外生成 LLM 深度分析 prompt"
      echo "  --aggressive    深度检查 + 过期/重复条目识别"
      echo "  --stale-days N  stale 阈值（默认 90 天）"
      exit 0
      ;;
    *)
      shift
      ;;
  esac
done

echo "🔍 知识库体检中..."
echo ""

# 收集 wiki 条目（排除维护类 special files）
ENTRIES=$(find "$WIKI_DIR" -maxdepth 1 -name "*.md" \
  ! -name "index.md" ! -name "log.md" ! -name "SCHEMA.md" 2>/dev/null || true)

if [ -z "$ENTRIES" ]; then
  echo "⚠️  没有 wiki 条目，请先编译"
  exit 1
fi

ENTRY_COUNT=$(echo "$ENTRIES" | wc -l | tr -d ' ')
echo "  找到 $ENTRY_COUNT 个条目"
echo ""

# ============================================
# Phase 1: 自动检查（无需 LLM）
# ============================================
echo "=== 自动检查 ==="
ISSUES=0

# Check 1: frontmatter 格式验证
while IFS= read -r entry; do
  if ! head -1 "$entry" | grep -q "^---$"; then
    echo "  ❌ 缺少 frontmatter: $(basename "$entry")"
    ISSUES=$((ISSUES + 1))
  fi
done <<< "$ENTRIES"

# Check 2: 必要字段检查（type, title）
while IFS= read -r entry; do
  for field in type title; do
    if ! grep -q "^${field}:" "$entry" 2>/dev/null; then
      echo "  ⚠️  缺少 $field 字段: $(basename "$entry")"
      ISSUES=$((ISSUES + 1))
    fi
  done
done <<< "$ENTRIES"

# Check 3: 断链检测（[[xxx]] 链接目标不存在）
ALL_FILENAMES=$(echo "$ENTRIES" | while IFS= read -r e; do basename "$e" .md; done)
while IFS= read -r entry; do
  links=$(grep -oE '\[\[[^]]+\]\]' "$entry" 2>/dev/null | sed 's/\[\[//;s/\]\]//' || true)
  if [ -n "$links" ]; then
    while IFS= read -r link; do
      if ! echo "$ALL_FILENAMES" | grep -qF "$link"; then
        echo "  🔗 断链: [[$link]] in $(basename "$entry")"
        ISSUES=$((ISSUES + 1))
      fi
    done <<< "$links"
  fi
done <<< "$ENTRIES"

# Check 4: 摘要长度检查
while IFS= read -r entry; do
  summary=$(sed -n '/^## 摘要/,/^##/{/^##/!p}' "$entry" 2>/dev/null | tr -d '\n' | sed 's/^[[:space:]]*//')
  if [ -n "$summary" ] && [ ${#summary} -gt 60 ]; then
    echo "  📏 摘要过长 (${#summary}字): $(basename "$entry")"
    ISSUES=$((ISSUES + 1))
  fi
done <<< "$ENTRIES"

# Check 5: stub 列表（status: stub 的条目，图书馆员的 todo）
STUB_LIST=$(grep -lE '^status:\s*stub' $ENTRIES 2>/dev/null || true)
if [ -n "$STUB_LIST" ]; then
  STUB_COUNT=$(echo "$STUB_LIST" | wc -l | tr -d ' ')
  echo ""
  echo "  🚧 待补全 stub 条目 ($STUB_COUNT):"
  while IFS= read -r f; do
    echo "     - $(basename "$f")"
  done <<< "$STUB_LIST"
  ISSUES=$((ISSUES + STUB_COUNT))
fi

# Check 6: 缺出处（sources: 段为空）
while IFS= read -r entry; do
  if ! grep -qE '^sources:' "$entry" 2>/dev/null && ! grep -qE '^source:' "$entry" 2>/dev/null; then
    echo "  📭 缺出处 (无 sources/source 字段): $(basename "$entry")"
    ISSUES=$((ISSUES + 1))
  fi
done <<< "$ENTRIES"

# Check 7: orphan — 没有任何其他条目链入它，且自己没出链
# 用 Python 一次扫完，比 bash 嵌套循环快得多
ORPHANS=$(WIKI_DIR="$WIKI_DIR" python3 - <<'PY'
import os, re, sys
wiki = os.environ["WIKI_DIR"]
SPECIAL = {"index.md", "log.md", "SCHEMA.md", "graph.mermaid"}
files = [f for f in os.listdir(wiki) if f.endswith(".md") and f not in SPECIAL and os.path.isfile(os.path.join(wiki, f))]
stems = {f[:-3] for f in files}
inbound = {s: 0 for s in stems}
outbound = {s: 0 for s in stems}
for f in files:
    stem = f[:-3]
    try:
        with open(os.path.join(wiki, f), "r", encoding="utf-8") as fh:
            text = fh.read()
    except Exception:
        continue
    for m in re.finditer(r"\[\[([^\]|]+)(?:\|[^\]]+)?\]\]", text):
        target = m.group(1).strip()
        if target == stem:
            continue
        outbound[stem] = outbound.get(stem, 0) + 1
        if target in inbound:
            inbound[target] = inbound.get(target, 0) + 1
orphans = sorted([s for s in stems if inbound[s] == 0 and outbound[s] == 0])
for o in orphans:
    print(o + ".md")
PY
)
if [ -n "$ORPHANS" ]; then
  ORPHAN_COUNT=$(echo "$ORPHANS" | wc -l | tr -d ' ')
  echo ""
  echo "  👤 孤儿条目 ($ORPHAN_COUNT，无入链且无出链):"
  echo "$ORPHANS" | sed 's/^/     - /'
  ISSUES=$((ISSUES + ORPHAN_COUNT))
fi

# Check 8: stale — last_updated 超过 STALE_DAYS 天 且 status 不是 stable
STALE=$(WIKI_DIR="$WIKI_DIR" STALE_DAYS="$STALE_DAYS" python3 - <<'PY'
import os, re
from datetime import datetime, timedelta
wiki = os.environ["WIKI_DIR"]
threshold = datetime.now() - timedelta(days=int(os.environ["STALE_DAYS"]))
SPECIAL = {"index.md", "log.md", "SCHEMA.md", "graph.mermaid"}
for f in sorted(os.listdir(wiki)):
    if not f.endswith(".md") or f in SPECIAL:
        continue
    p = os.path.join(wiki, f)
    if not os.path.isfile(p):
        continue
    try:
        with open(p, "r", encoding="utf-8") as fh:
            text = fh.read()
    except Exception:
        continue
    fm = {}
    if text.startswith("---"):
        m = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
        if m:
            for line in m.group(1).split("\n"):
                if ":" in line:
                    k, _, v = line.partition(":")
                    fm[k.strip()] = v.strip().strip('"').strip("'")
    status = fm.get("status", "")
    if status == "stable":
        continue
    last = fm.get("last_updated", "") or fm.get("date", "")
    if not re.match(r"^\d{4}-\d{2}-\d{2}", last):
        continue
    try:
        d = datetime.strptime(last[:10], "%Y-%m-%d")
    except ValueError:
        continue
    if d < threshold:
        print(f"{f} ({last}, status={status or 'none'})")
PY
)
if [ -n "$STALE" ]; then
  STALE_COUNT=$(echo "$STALE" | wc -l | tr -d ' ')
  echo ""
  echo "  🕰️  陈旧条目 ($STALE_COUNT，>${STALE_DAYS}天 且 status≠stable):"
  echo "$STALE" | sed 's/^/     - /'
  ISSUES=$((ISSUES + STALE_COUNT))
fi

# ===== v2.7+ schema checks: typed relations + confidence =====
V27_REPORT=$(WIKI_DIR="$WIKI_DIR" python3 - <<'PY'
import os, re
wiki = os.environ["WIKI_DIR"]
SPECIAL = {"index.md", "log.md", "SCHEMA.md", "graph.mermaid"}
ALLOWED = {"uses", "depends-on", "extends", "part-of", "contradicts",
           "supersedes", "superseded-by", "related"}

# 把 frontmatter 用更宽松的方式抽出（支持嵌套 relations 块）
def parse_fm(text):
    fm_simple = {}
    relations = {}
    confidence = None
    if not text.startswith("---"):
        return fm_simple, relations, confidence
    m = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
    if not m:
        return fm_simple, relations, confidence
    block = m.group(1)
    in_relations = False
    for raw in block.split("\n"):
        if not raw.strip():
            continue
        # 顶层键: 无前导空格
        if not raw.startswith((" ", "\t")):
            if raw.startswith("relations:"):
                in_relations = True
                continue
            in_relations = False
            if ":" in raw:
                k, _, v = raw.partition(":")
                v = v.strip().strip('"').strip("'")
                if k.strip() == "confidence":
                    try:
                        confidence = float(v)
                    except ValueError:
                        pass
                else:
                    fm_simple[k.strip()] = v
        elif in_relations:
            # "  uses: [a, b]" 或 "  uses:" 后接 "    - x"（这里只支持单行）
            line = raw.strip()
            if ":" in line:
                rkey, _, rval = line.partition(":")
                rkey = rkey.strip()
                rval = rval.strip()
                if rval.startswith("[") and rval.endswith("]"):
                    items = [s.strip().strip('"').strip("'") for s in rval[1:-1].split(",") if s.strip()]
                    relations[rkey] = items
                elif rval:
                    relations[rkey] = [rval.strip('"').strip("'")]
                else:
                    relations[rkey] = []
    return fm_simple, relations, confidence

pages = {}
for f in sorted(os.listdir(wiki)):
    if not f.endswith(".md") or f in SPECIAL:
        continue
    p = os.path.join(wiki, f)
    if not os.path.isfile(p):
        continue
    try:
        text = open(p, "r", encoding="utf-8").read()
    except Exception:
        continue
    fm, rels, conf = parse_fm(text)
    pages[f[:-3]] = {"fm": fm, "relations": rels, "confidence": conf, "text": text, "path": p}

issues = []

# (a) 未知关系类型
for stem, info in pages.items():
    for rtype in info["relations"].keys():
        if rtype not in ALLOWED:
            issues.append(("unknown-relation", stem, f"relations.{rtype} 不在枚举内（{','.join(sorted(ALLOWED))}）"))

# (b) supersedes ↔ superseded-by 必须互指（强制 error）
for stem, info in pages.items():
    for tgt in info["relations"].get("supersedes", []):
        tgt_info = pages.get(tgt)
        if not tgt_info:
            issues.append(("missing-supersede-target", stem, f"supersedes -> {tgt} 但 {tgt}.md 不存在"))
            continue
        back = tgt_info["relations"].get("superseded-by", [])
        if stem not in back:
            issues.append(("supersession-asymmetric", stem, f"supersedes [{tgt}] 但 {tgt}.md 没回写 superseded-by [{stem}]"))
    for tgt in info["relations"].get("superseded-by", []):
        tgt_info = pages.get(tgt)
        if not tgt_info:
            issues.append(("missing-superseded-by-target", stem, f"superseded-by -> {tgt} 但 {tgt}.md 不存在"))
            continue
        back = tgt_info["relations"].get("supersedes", [])
        if stem not in back:
            issues.append(("supersession-asymmetric", stem, f"superseded-by [{tgt}] 但 {tgt}.md 没回写 supersedes [{stem}]"))

# (c) contradicts 双向 warning（不强制，仅 warning）
for stem, info in pages.items():
    for tgt in info["relations"].get("contradicts", []):
        tgt_info = pages.get(tgt)
        if not tgt_info:
            continue
        back = tgt_info["relations"].get("contradicts", [])
        if stem not in back:
            issues.append(("contradicts-asymmetric", stem, f"contradicts [{tgt}] 但 {tgt}.md 未回链；建议双向标注"))

# (d) confidence < 0.5 但正文没 TODO 标记
for stem, info in pages.items():
    if info["confidence"] is not None and info["confidence"] < 0.5:
        if "<!-- TODO" not in info["text"] and "TODO:" not in info["text"]:
            issues.append(("low-confidence-no-todo", stem, f"confidence={info['confidence']} < 0.5 但正文没 <!-- TODO --> 标记"))

# (e) confidence ≥ 0.9 但 status 不是 stable
for stem, info in pages.items():
    if info["confidence"] is not None and info["confidence"] >= 0.9:
        if info["fm"].get("status", "") != "stable":
            issues.append(("high-confidence-not-stable", stem, f"confidence={info['confidence']} ≥ 0.9 但 status={info['fm'].get('status', 'none')}"))

# 输出（行格式: <kind>\t<stem>\t<msg>）
for kind, stem, msg in issues:
    print(f"{kind}\t{stem}\t{msg}")
PY
)

if [ -n "$V27_REPORT" ]; then
  V27_COUNT=$(echo "$V27_REPORT" | wc -l | tr -d ' ')
  echo ""
  echo "  🧬 v2.7 schema 问题 ($V27_COUNT):"
  echo "$V27_REPORT" | awk -F'\t' '{
    icon = "•"
    if ($1 == "unknown-relation") icon = "❓"
    else if ($1 ~ /supersession/) icon = "⚡"
    else if ($1 ~ /missing-supers/) icon = "🔗"
    else if ($1 == "contradicts-asymmetric") icon = "⚖️"
    else if ($1 == "low-confidence-no-todo") icon = "🟡"
    else if ($1 == "high-confidence-not-stable") icon = "🟢"
    printf "     %s [%s] %s — %s\n", icon, $1, $2, $3
  }'
  ISSUES=$((ISSUES + V27_COUNT))
fi

echo ""
if [ "$ISSUES" -eq 0 ]; then
  echo "✅ 自动检查通过，0 个问题"
else
  echo "⚠️  自动检查完成: $ISSUES 个问题"
fi

# 写日志
"$SCRIPT_DIR/kb-log" --scope "$KB_SCOPE" lint "$ISSUES issues found" "stale_days=$STALE_DAYS" >/dev/null 2>&1 || true

# ============================================
# Phase 2: LLM 深度分析（--deep 时触发）
# ============================================
if [ "$DEEP" = true ]; then
  echo ""
  echo "=== LLM 深度分析 ==="

  mkdir -p "$CACHE_DIR"

  cat > "$CACHE_DIR/lint_prompt.md" << 'LINT_EOF'
# 知识库体检

检查以下 wiki 条目的健康状况：

### 检查项
- [ ] 文件格式 valid Markdown
- [ ] 每个条目有 type/title/concepts 元信息
- [ ] 摘要简洁（50字内）
- [ ] [[链接]] 都有对应条目
- [ ] 无 orphaned 条目

LINT_EOF

  if [ "$AGGRESSIVE" = true ]; then
    echo "" >> "$CACHE_DIR/lint_prompt.md"
    echo "### 深度检查" >> "$CACHE_DIR/lint_prompt.md"
    echo "- [ ] 标记超过 30 天未更新的条目" >> "$CACHE_DIR/lint_prompt.md"
    echo "- [ ] 识别重复内容" >> "$CACHE_DIR/lint_prompt.md"
    echo "- [ ] 建议可合并的相似条目" >> "$CACHE_DIR/lint_prompt.md"
  fi

  echo "" >> "$CACHE_DIR/lint_prompt.md"
  echo "请扫描以下条目并生成体检报告：" >> "$CACHE_DIR/lint_prompt.md"
  echo "" >> "$CACHE_DIR/lint_prompt.md"

  while IFS= read -r entry; do
    echo "### $entry" >> "$CACHE_DIR/lint_prompt.md"
    echo '```' >> "$CACHE_DIR/lint_prompt.md"
    cat "$entry" >> "$CACHE_DIR/lint_prompt.md"
    echo '```' >> "$CACHE_DIR/lint_prompt.md"
    echo "" >> "$CACHE_DIR/lint_prompt.md"
  done <<< "$ENTRIES"

  echo "📋 LLM 深度分析 prompt 已生成: $CACHE_DIR/lint_prompt.md"
  echo ""
  echo "下一步: 告诉 Agent '帮我深度体检知识库'"
fi
