#!/bin/bash
# kb-bases — 生成 Obsidian Bases (.base) 数据库视图文件 (v2.8.0)
#
# Obsidian 1.9.10+ 原生 Bases 功能：把任何 .md 集合变成 dynamic database
# (frontmatter properties → table/card 视图)。我们的 wiki 已有
# confidence/status/relations/type/date frontmatter，正好做成 5 张视图。
#
# 用法：
#   kb-bases                          # 生成 5 个 .base 到 wiki/.bases/
#   kb-bases --vault-out               # 同时输出到 Obsidian vault/知识库/.bases/（需 obsidian.enabled）
#   kb-bases --scope shared            # shared scope
#   kb-bases --list                    # 列出所有 base 文件

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/kb-scope.sh"
kb_parse_scope "$@"
set -- "${KB_ARGS[@]}"

WIKI_DIR="${KB_DATA_DIR}/wiki"
BASES_DIR="${WIKI_DIR}/.bases"

VAULT_OUT=false
LIST_ONLY=false
while [[ $# -gt 0 ]]; do
  case $1 in
    --vault-out) VAULT_OUT=true; shift ;;
    --list)      LIST_ONLY=true; shift ;;
    --help|-h)
      cat <<EOF
用法: kb-bases [--scope agent|shared] [--vault-out] [--list]

  生成 5 个 Obsidian Bases 文件，把当前 wiki/ 变成可查询的数据库视图：

    1. 知识库-by-confidence.base  按 confidence 倒序，stub/低信度高亮
    2. 知识库-by-status.base      stable / draft / superseded 分组
    3. 知识库-by-type.base        entity / concept / source / synthesis
    4. 知识库-stub-orphan.base    待补全清单（confidence<0.5 或 stub 标记）
    5. 知识库-recent.base         按 date 倒序，看最近变动

  --vault-out  同步到 vault/知识库/<scope>/.bases/（依赖 obsidian.enabled=true）
  --list       只列出已生成的 base 文件，不重新生成
EOF
      exit 0
      ;;
    *) shift ;;
  esac
done

if [ "$LIST_ONLY" = true ]; then
  if [ -d "$BASES_DIR" ]; then
    echo "📊 已生成的 Bases (scope=$KB_SCOPE):"
    ls -1 "$BASES_DIR"/*.base 2>/dev/null | sed 's|^|  |' || echo "  (无)"
  else
    echo "  (尚未生成；运行 kb-bases 创建)"
  fi
  exit 0
fi

if [ ! -d "$WIKI_DIR" ]; then
  echo "❌ wiki/ 不存在: $WIKI_DIR" >&2
  echo "   先 kb-ingest + kb-compile 创建条目，或 kb-* 任意命令会自动激活作用域。" >&2
  exit 1
fi

mkdir -p "$BASES_DIR"

# Obsidian Bases YAML 语法（v1.9.10+）：
#   filters / formulas / properties / views
# 参考：https://docs.obsidian.md/plugins/guides/bases-view
# 我们的 wiki frontmatter 字段已对齐：confidence(num), status(str),
# type(str), relations(list), date(str), tags(list)

write_base() {
  local fname="$1"
  local content="$2"
  local path="$BASES_DIR/$fname"
  echo "$content" > "$path"
  echo "  ✓ $fname"
}

echo "📊 生成 Obsidian Bases (scope=$KB_SCOPE) → $BASES_DIR"

# 1. by confidence —— 按可信度倒序，看哪些条目最可靠
write_base "知识库-by-confidence.base" "$(cat <<'BASE'
# Auto-generated by kb-bases (v2.8.0). Manual edits will be overwritten.
filters:
  and:
    - file.ext == "md"
    - file.name != "index"
    - file.name != "log"
    - file.name != "SCHEMA"
properties:
  - file.name
  - confidence
  - status
  - type
  - date
views:
  - type: table
    name: 按可信度倒序
    order:
      - file.name
      - confidence
      - status
      - type
      - date
    sort:
      - property: confidence
        direction: desc
BASE
)"

# 2. by status —— stable / draft / superseded 分组
write_base "知识库-by-status.base" "$(cat <<'BASE'
# Auto-generated by kb-bases. 按 status 分组看哪些可发布、哪些 WIP、哪些被取代
filters:
  and:
    - file.ext == "md"
    - file.name != "index"
    - file.name != "log"
    - file.name != "SCHEMA"
properties:
  - file.name
  - status
  - confidence
  - type
  - superseded-by
views:
  - type: table
    name: 按状态分组
    order:
      - status
      - file.name
      - confidence
      - type
      - superseded-by
    sort:
      - property: status
        direction: asc
      - property: confidence
        direction: desc
BASE
)"

# 3. by type —— Karpathy 原方案的 entity/concept/source/synthesis 分类
write_base "知识库-by-type.base" "$(cat <<'BASE'
# Auto-generated by kb-bases. Karpathy 原方案 wiki 子目录维度
filters:
  and:
    - file.ext == "md"
    - file.name != "index"
    - file.name != "log"
    - file.name != "SCHEMA"
properties:
  - file.name
  - type
  - status
  - confidence
  - tags
views:
  - type: table
    name: 按类型分组
    order:
      - type
      - file.name
      - status
      - confidence
      - tags
    sort:
      - property: type
        direction: asc
      - property: file.name
        direction: asc
BASE
)"

# 4. stub & orphan —— 需要补全的条目
write_base "知识库-stub-orphan.base" "$(cat <<'BASE'
# Auto-generated by kb-bases. 待补全：confidence<0.5 或 status=stub 或缺出处
filters:
  and:
    - file.ext == "md"
    - file.name != "index"
    - file.name != "log"
    - file.name != "SCHEMA"
    - or:
        - confidence < 0.5
        - status == "stub"
        - status == "draft"
properties:
  - file.name
  - confidence
  - status
  - tags
  - date
views:
  - type: table
    name: 待补全清单
    order:
      - file.name
      - confidence
      - status
      - date
    sort:
      - property: confidence
        direction: asc
BASE
)"

# 5. recent —— 按 date 倒序看最近活跃
write_base "知识库-recent.base" "$(cat <<'BASE'
# Auto-generated by kb-bases. 按 date 倒序，看最近修订动态
filters:
  and:
    - file.ext == "md"
    - file.name != "index"
    - file.name != "log"
    - file.name != "SCHEMA"
properties:
  - file.name
  - date
  - status
  - confidence
  - type
views:
  - type: table
    name: 最近修订
    order:
      - date
      - file.name
      - status
      - confidence
      - type
    sort:
      - property: date
        direction: desc
BASE
)"

# 同步到 vault（如果 --vault-out）
if [ "$VAULT_OUT" = true ]; then
  CONFIG_FILE=""
  for cf in "$SCRIPT_DIR/../config.json" "$SCRIPT_DIR/../config.example.json"; do
    [ -f "$cf" ] && CONFIG_FILE="$cf" && break
  done
  if [ -z "$CONFIG_FILE" ]; then
    echo "⚠️  未找到 config.json，跳过 --vault-out" >&2
  else
    VAULT_PATH=$(python3 -c "
import json, sys
with open('$CONFIG_FILE') as f: c=json.load(f)
ob=c.get('obsidian',{})
print(ob.get('vault_path','') if ob.get('enabled') else '')
")
    if [ -z "$VAULT_PATH" ] || [ ! -d "$VAULT_PATH" ]; then
      echo "⚠️  obsidian.enabled=false 或 vault_path 无效，跳过 --vault-out" >&2
    else
      VAULT_BASES="${VAULT_PATH}/知识库/${KB_SCOPE}/.bases"
      mkdir -p "$VAULT_BASES"
      cp "$BASES_DIR"/*.base "$VAULT_BASES/"
      echo "  → vault: $VAULT_BASES"
    fi
  fi
fi

# 写 log（kb-log 用位置参数 <event> <summary>）
"$SCRIPT_DIR/kb-log" --scope "$KB_SCOPE" bases \
  "生成 5 个 Obsidian Bases 视图" 2>/dev/null || true

echo
echo "✅ 完成。Obsidian 1.9.10+ 自动识别 .base 文件为数据库视图。"
echo "   在 Obsidian 里打开任一 .base 即可使用 table 视图过滤/排序/分组。"
