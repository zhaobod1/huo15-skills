#!/bin/bash
# kb-compile — 编译 raw/ → wiki/（Agent 专属版本）
# 自动使用当前 Agent 的 KB_DATA_DIR
# Phase 4: 集成 LLM 自动调用

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_ROOT="$(dirname "$SCRIPT_DIR")"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/kb-scope.sh"
kb_parse_scope "$@"
set -- "${KB_ARGS[@]}"

RAW_DIR="${KB_DATA_DIR}/raw"
WIKI_DIR="${KB_DATA_DIR}/wiki"
CACHE_DIR="${KB_DATA_DIR}/cache"

if [ ! -d "$KB_DATA_DIR" ]; then
  echo "📦 首次使用，正在激活知识库（scope=$KB_SCOPE）..."
  "$SCRIPT_DIR/activate.sh" --scope "$KB_SCOPE"
fi

INCREMENTAL=false
USE_LLM=true
OBSIDIAN_SYNC=true

while [[ $# -gt 0 ]]; do
  case $1 in
    --incremental)
      INCREMENTAL=true
      shift
      ;;
    --no-llm)
      USE_LLM=false
      shift
      ;;
    --obsidian)
      OBSIDIAN_SYNC=true
      shift
      ;;
    --no-obsidian)
      OBSIDIAN_SYNC=false
      shift
      ;;
    --help)
      echo "用法: kb-compile [--incremental] [--no-llm] [--obsidian|--no-obsidian]"
      echo "  --incremental  仅编译新文档"
      echo "  --no-llm      仅生成 prompt，不调用 LLM"
      echo "  --obsidian    编译后同步到 Obsidian vault（默认）"
      echo "  --no-obsidian 编译后不同步到 Obsidian"
      exit 0
      ;;
    *)
      shift
      ;;
  esac
done

echo "📚 知识库编译中..."
echo "  数据目录: $KB_DATA_DIR"

# 检查 raw 目录
if [ ! -d "$RAW_DIR" ] || [ -z "$(ls -A "$RAW_DIR" 2>/dev/null)" ]; then
  echo "⚠️  raw/ 目录为空，请先入库文档: kb-ingest --url 'https://...'"
  exit 1
fi

# 收集待编译文档
if [ "$INCREMENTAL" = true ]; then
  # 增量：仅编译新增的 ready 文档（排除已编译的）
  DOCS=$(find "$RAW_DIR" -name "*.md" 2>/dev/null | xargs grep -l "status: ready" 2>/dev/null | grep -v "_compiled" || true)
else
  # 全量：编译所有 ready 状态的文档
  DOCS=$(find "$RAW_DIR" -name "*.md" 2>/dev/null | xargs grep -l "status: ready" 2>/dev/null | sort)
fi

if [ -z "$DOCS" ]; then
  echo "⚠️  没有待编译的文档"
  exit 1
fi

DOC_COUNT=$(echo "$DOCS" | wc -l | tr -d ' ')
echo "  找到 $DOC_COUNT 个待编译文档"

# 构建编译 prompt（用外置 prompt 模板 + 自动注入 wiki 现状 + SCHEMA）
echo "📝 生成编译 prompt（Karpathy librarian 模式）..."

PROMPT_TEMPLATE="$SCRIPT_DIR/prompts/compile.md"
if [ ! -f "$PROMPT_TEMPLATE" ]; then
  echo "❌ 缺 prompt 模板: $PROMPT_TEMPLATE"
  exit 1
fi

PROMPT_OUT="$CACHE_DIR/compile_prompt.md"

# 1) 写入外置 prompt 模板
cp "$PROMPT_TEMPLATE" "$PROMPT_OUT"

# 2) 注入：现有 wiki 文件清单
{
  echo ""
  echo "## 现有 wiki 文件清单（找反链目标用）"
  echo ""
  echo '```'
  find "$WIKI_DIR" -maxdepth 1 -name "*.md" \
    ! -name "index.md" ! -name "log.md" ! -name "SCHEMA.md" 2>/dev/null \
    | xargs -I {} basename {} .md | sort || true
  echo '```'
} >> "$PROMPT_OUT"

# 3) 注入 SCHEMA.md（如果有）
SCHEMA_FILE="$WIKI_DIR/SCHEMA.md"
if [ -f "$SCHEMA_FILE" ]; then
  {
    echo ""
    echo "## SCHEMA.md（图书馆员守则；先读完再动笔）"
    echo ""
    echo '```markdown'
    cat "$SCHEMA_FILE"
    echo '```'
  } >> "$PROMPT_OUT"
fi

# 4) 注入待编译 raw 文档
{
  echo ""
  echo "## 待编译 raw 文档"
  echo ""
} >> "$PROMPT_OUT"

DOC_ARRAY=()
while IFS= read -r doc; do
  DOC_ARRAY+=("$doc")
  {
    echo "### 文件: $doc"
    echo '```'
    cat "$doc"
    echo ''
    echo '```'
    echo ""
  } >> "$PROMPT_OUT"
done <<< "$DOCS"

{
  echo ""
  echo "---"
  echo ""
  echo "## 开始编译"
  echo ""
  echo "请按 SCHEMA.md 规范输出 wiki 条目（用 ---FILE: xxx.md--- 分隔），结尾给出 ---SUMMARY--- 区块。"
} >> "$PROMPT_OUT"

echo "  ✅ Prompt 已生成: $PROMPT_OUT"

# 调用 LLM
if [ "$USE_LLM" = true ]; then
  echo ""
  echo "🤖 调用 LLM 进行编译..."
  
  # 调用 kb-llm.py（使用数组避免 eval 的路径问题）
  CMD_ARGS=(python3 "$SCRIPT_DIR/kb-llm.py" --prompt "$CACHE_DIR/compile_prompt.md" --wiki-dir "$WIKI_DIR" --raw-docs "${DOC_ARRAY[@]}")

  echo "  命令: ${CMD_ARGS[*]}"
  echo ""

  if "${CMD_ARGS[@]}"; then
    echo ""
    echo "✅ 编译完成！"
    echo ""

    # 自动重建 index.md（Karpathy 三件套之一）
    if [ -x "$SCRIPT_DIR/kb-index" ]; then
      "$SCRIPT_DIR/kb-index" --scope "$KB_SCOPE" 2>&1 | sed 's/^/  /' || true
    fi

    # 写日志
    NEW_COUNT=$(find "$WIKI_DIR" -maxdepth 1 -name "*.md" -newer "$RAW_DIR" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
    "$SCRIPT_DIR/kb-log" --scope "$KB_SCOPE" compile "$DOC_COUNT raw → ~$NEW_COUNT wiki entries touched" >/dev/null 2>&1 || true

    # 同步到 Obsidian（带当前 scope）
    if [ "$OBSIDIAN_SYNC" = true ]; then
      echo "📦 同步到 Obsidian vault (scope=$KB_SCOPE)..."
      if "$SCRIPT_DIR/obsidian-sync.sh" --scope "$KB_SCOPE" --dry-run 2>/dev/null | grep -q "未启用"; then
        echo "   ⚠️ Obsidian 未启用，忽略（vault_path 未配置）"
      else
        SYNC_RESULT=$("$SCRIPT_DIR/obsidian-sync.sh" --scope "$KB_SCOPE" 2>&1 || true)
        if echo "$SYNC_RESULT" | grep -q "同步完成\|同步成功\|updated"; then
          echo "   ✅ 已同步到 Obsidian vault"
        else
          echo "   ℹ️ Obsidian 同步: $(echo "$SYNC_RESULT" | tail -3)"
        fi
      fi
    fi

    echo ""
    echo "    kb-search '关键词'  # 搜索知识库"
    echo "    kb-lint            # 体检知识库"
  else
    echo ""
    echo "⚠️ LLM 调用失败，已保存 prompt 到: $CACHE_DIR/compile_prompt.md"
    echo ""
    echo "可手动处理:
      1. 阅读 prompt 内容
      2. 手动生成 wiki 条目到 $WIKI_DIR/
      3. 或告诉 贾维斯 '帮我编译知识库'"
  fi
else
  echo ""
  echo "⚠️ --no-llm 模式，仅生成 prompt"
  echo "   告诉 贾维斯 '帮我编译知识库' 继续"
fi
