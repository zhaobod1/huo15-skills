{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "huo15-knowledge-base 配置",
  "llm": {
    "model": "minimax/MiniMax-M2.7",
    "provider": "openclaw",
    "temperature": 0.7
  },
  "paths": {
    "raw": "raw",
    "wiki": "wiki",
    "cache": "cache"
  },
  "compile": {
    "auto_trigger": false,
    "batch_size": 10,
    "incremental": true
  },
  "obsidian": {
    "enabled": false,
    "vault_path": null
  },
  "search": {
    "default_format": "markdown",
    "max_results": 20
  }
}
