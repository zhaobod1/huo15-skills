<page-meta page-style="overflow-x: hidden;">
  <navigation-bar title="火一五 · 商品" front-color="#1a1a1a" background-color="#fafaf6" />
</page-meta>

<view class="page" style="padding-top: env(safe-area-inset-top); padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);">
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <text class="hero-kicker">2026 春 · 限定预售</text>
      <text class="hero-title">慢工{'\n'}出细活</text>
      <view class="hero-cta">
        <text>去看看</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-x="true" class="chips" enhanced="true" show-scrollbar="{{false}}">
    <view class="chip selected">全部</view>
    <view class="chip">手作</view>
    <view class="chip">茶具</view>
    <view class="chip">书籍</view>
    <view class="chip">工具</view>
    <view class="chip">福袋</view>
  </scroll-view>

  <view class="grid">
    <view class="card" wx:for="{{products}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
      <view class="img" style="background-color: {{item.tone}};">
        <text class="img-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
      </view>
      <view class="info">
        <text class="name">{{item.name}}</text>
        <view class="meta">
          <text class="price">¥{{item.price}}</text>
          <text class="sold">已售 {{item.sold}}</text>
        </view>
      </view>
    </view>
  </view>

  <text class="footer-note">微信小程序 starter — wxml + wxss + page-meta + 原生 tabBar 配置三件套。**避开 WeUI 默认皮**，自绘 hero / chips / 商品 grid，rpx 适配 750rpx 屏宽。视觉延续 ORGANIC 流派暖色调，避紫渐变红线。</text>
</view>
